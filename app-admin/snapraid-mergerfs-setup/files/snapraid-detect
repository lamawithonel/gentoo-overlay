#!/bin/sh
# Detect candidate USB drives and assign roles via interactive
# multi-select.  Writes /etc/snapraid-roles.conf.  Idempotent against
# an existing roles file when its IDs still resolve to present
# devices and the user does not pass --force.
#
# Usage: snapraid-detect [--force]
set -o errexit
set -o nounset

. /usr/local/lib/snapraid-helpers.sh
sr_require_root
sr_parse_force "$@"

if ! command -v gum >/dev/null 2>&1; then
sr_err 'snapraid-detect requires gum (charmbracelet/gum) for' \
'interactive drive selection'
exit 1
fi
if ! command -v column >/dev/null 2>&1; then
sr_err 'snapraid-detect requires column(1) from util-linux'
exit 1
fi

sr_header 'Detect drives and assign roles'

_expected=$((SR_PARITY_COUNT + SR_DATA_COUNT))

# Enumerate candidate USB block-device whole-disk symlinks.
_candidates=$(
for _link in $SR_DRIVE_GLOB; do
[ -e "$_link" ] || continue
case "$_link" in *-part*) continue ;; esac
printf '%s\n' "$_link"
done | LC_ALL=C sort
)
_count=$(printf '%s\n' "$_candidates" | grep -c '^/' || true)

if [ "$_count" -lt "$_expected" ]; then
sr_err "found ${_count} candidate USB drives," \
"need at least ${_expected}"
exit 1
fi

# Build a tab-separated table: <by-path>\t<id-for-roles-file>.
# Prefer the ata-* alias (carries the serial, survives bridge swaps
# that preserve SAT pass-through).  Fall back to the usb-* basename
# when no ata-* alias exists for the underlying kernel device.
_table=$(mktemp)
trap 'rm -f "$_table"' EXIT

printf '%s\n' "$_candidates" | while read -r _link; do
[ -n "$_link" ] || continue
_kname=$(readlink -f "$_link")

_ata=''
for _alt in /dev/disk/by-id/ata-*; do
[ -e "$_alt" ] || continue
case "$_alt" in *-part*) continue ;; esac
if [ "$(readlink -f "$_alt")" = "$_kname" ]; then
_ata=${_alt##*/}
break
fi
done

_bypath=''
for _bp in /dev/disk/by-path/*; do
[ -e "$_bp" ] || continue
case "$_bp" in *-part*) continue ;; esac
if [ "$(readlink -f "$_bp")" = "$_kname" ]; then
_bypath=${_bp##*/}
break
fi
done

_id=${_ata:-${_link##*/}}
[ -n "$_bypath" ] || _bypath='(no-by-path)'
printf '%s\t%s\n' "$_bypath" "$_id" >> "$_table"
done

# Align columns for human readability.  The id remains the last
# whitespace-separated field, so awk '{print $NF}' recovers it.
_rows=$(column -t -s "$(printf '\t')" "$_table")

# Two-stage selection: parity drives first, then data drives.  Using
# `gum choose --limit N` gives multi-select with a hard cap; we
# also validate that the user actually selected N (gum allows fewer).
_pick() {
# $1 = role label, $2 = limit, stdin = candidate rows
gum choose \
--limit "$2" \
--header "Select ${2} ${1} drive(s) -- space to toggle, enter to confirm"
}

sr_info "Pick ${SR_PARITY_COUNT} parity drives, then" \
"${SR_DATA_COUNT} data drives."

_parity_sel=$(printf '%s\n' "$_rows" \
| _pick 'parity' "$SR_PARITY_COUNT") || exit 1
_parity_n=$(printf '%s\n' "$_parity_sel" | grep -c . || true)
if [ "$_parity_n" -ne "$SR_PARITY_COUNT" ]; then
sr_err "selected ${_parity_n} parity drives," \
"expected ${SR_PARITY_COUNT}"
exit 1
fi

# Filter parity selections out of the remaining candidates.  GNU
# grep -F treats embedded newlines in PATTERN as alternative fixed
# strings, so this excludes any row that exactly matches one of
# the parity rows.
_remaining=$(printf '%s\n' "$_rows" | grep -vxF "$_parity_sel")

_data_sel=$(printf '%s\n' "$_remaining" \
| _pick 'data' "$SR_DATA_COUNT") || exit 1
_data_n=$(printf '%s\n' "$_data_sel" | grep -c . || true)
if [ "$_data_n" -ne "$SR_DATA_COUNT" ]; then
sr_err "selected ${_data_n} data drives," \
"expected ${SR_DATA_COUNT}"
exit 1
fi

_extract_ids() { awk '{print $NF}'; }

_proposed=$(
printf '# Generated by snapraid-detect\n'
printf '# Format: ROLE INDEX BY_ID_PATH\n'
_i=1
printf '%s\n' "$_parity_sel" | _extract_ids | while read -r _id; do
[ -n "$_id" ] || continue
printf 'parity %d /dev/disk/by-id/%s\n' "$_i" "$_id"
_i=$((_i + 1))
done
_i=1
printf '%s\n' "$_data_sel" | _extract_ids | while read -r _id; do
[ -n "$_id" ] || continue
printf 'data %d /dev/disk/by-id/%s\n' "$_i" "$_id"
_i=$((_i + 1))
done
)

# Idempotency: if the existing file's non-comment lines match the
# proposal, do nothing.  Otherwise show a diff and confirm.
if [ -f "$SR_ROLES_FILE" ] && [ "$SR_FORCE" != '1' ]; then
_existing=$(grep -v '^#' "$SR_ROLES_FILE" | grep -v '^$' || true)
_new=$(printf '%s\n' "$_proposed" | grep -v '^#' \
| grep -v '^$' || true)
if [ "$_existing" = "$_new" ]; then
sr_skip "${SR_ROLES_FILE} already up to date"
cat "$SR_ROLES_FILE"
exit 0
fi

sr_warn "${SR_ROLES_FILE} exists but differs from selection"
gum style --margin '1 2' --bold 'Existing:'
gum style --foreground "$_SR_DIM_FG" --margin '0 4' \
"$(cat "$SR_ROLES_FILE")"
gum style --margin '1 2' --bold 'Proposed:'
gum style --foreground "$_SR_HDR_FG" --margin '0 4' \
"$_proposed"

sr_confirm \
'Overwrite roles file?' \
"This replaces ${SR_ROLES_FILE}.  If SnapRAID has already
synced parity, changing role assignments WILL break parity
recovery.  Only proceed if no sync has run yet, or if a drive
was physically replaced." \
"cat > ${SR_ROLES_FILE} <<EOF (proposed content shown above)" \
|| exit 1
fi

# Atomic write.
_tmp=$(mktemp "${SR_ROLES_FILE}.XXXXXX")
printf '%s\n' "$_proposed" > "$_tmp"
chmod 0644 "$_tmp"
mv "$_tmp" "$SR_ROLES_FILE"

sr_ok "wrote ${SR_ROLES_FILE}"
cat "$SR_ROLES_FILE"
