#!/bin/sh
# Generate /etc/snapraid.conf.  Idempotent.
# Usage: snapraid-genconf [--force]
set -o errexit
set -o nounset

. /usr/local/lib/snapraid-helpers.sh
sr_require_root
sr_parse_force "$@"

sr_header 'Generate /etc/snapraid.conf'

[ -f "$SR_ROLES_FILE" ] || {
	sr_err "${SR_ROLES_FILE} missing; run snapraid-detect first"
	exit 1
}

# Build the proposed config.
_proposed=$(
	cat <<-'HEADER'
		# /etc/snapraid.conf - generated by snapraid-genconf.
		# Two-parity configuration with three data disks.
		# Tolerates any two simultaneous disk failures.

		blocksize 256
		hashsize 16
		autosave 50

	HEADER

	# Parity lines.
	while read -r _role _idx _link; do
		[ "$_role" = 'parity' ] || continue
		_mnt="/mnt/snapraid0/parity${_idx}"
		if [ "$_idx" = '1' ]; then
			printf 'parity %s/snapraid.parity\n' "$_mnt"
		else
			printf '2-parity %s/snapraid.2-parity\n' "$_mnt"
		fi
	done < "$SR_ROLES_FILE"

	# Content files: one per drive for redundancy.
	printf '\n'
	while read -r _role _idx _link; do
		case "$_role" in '#'*|'') continue ;; esac
		printf 'content /mnt/snapraid0/%s%s/snapraid.content\n' \
			"$_role" "$_idx"
	done < "$SR_ROLES_FILE"

	# Data disks.  d1/d2/d3 names are stored in parity, must not
	# change after first sync.
	printf '\n'
	while read -r _role _idx _link; do
		[ "$_role" = 'data' ] || continue
		printf 'data d%d /mnt/snapraid0/data%d/\n' "$_idx" "$_idx"
	done < "$SR_ROLES_FILE"

	cat <<-'EXCLUDES'

		exclude *.unrecoverable
		exclude /tmp/
		exclude /lost+found/
		exclude .snapraid.content*
		exclude .DS_Store
		exclude Thumbs.db

	EXCLUDES

	# SnapRAID's smartctl directive is per-disk:
	#     smartctl <name> <smartctl args...>
	# where <name> matches the data/parity disk name declared
	# above ('parity', '2-parity', 'd1', ...).  A bare
	# 'smartctl -d sat' makes SnapRAID parse '-d' as the disk
	# name and abort 'snapraid check' with:
	#     Unknown 'smartctl' name '-d'
	# Most USB enclosures need '-d sat' to bridge SCSI->ATA so
	# the SMART info command works; we emit it for every disk.
	while read -r _role _idx _link; do
		case "$_role" in '#'*|'') continue ;; esac
		case "$_role" in
			parity)
				if [ "$_idx" = '1' ]; then
					_name='parity'
				else
					_name="${_idx}-parity"
				fi ;;
			data) _name="d${_idx}" ;;
			*) continue ;;
		esac
		printf 'smartctl %s -d sat\n' "$_name"
	done < "$SR_ROLES_FILE"
)

# Idempotency check.
if [ -f "$SR_CONF" ] && [ "$SR_FORCE" != '1' ]; then
	if [ "$(cat "$SR_CONF")" = "$_proposed" ]; then
		sr_skip "${SR_CONF} already up to date"
		exit 0
	fi

	sr_warn "${SR_CONF} exists but differs"
	_diff=$(diff -u "$SR_CONF" - <<EOF || true
$_proposed
EOF
)
	gum style --foreground "$_SR_DIM_FG" --margin '0 2' -- "$_diff"

	sr_confirm \
		'Overwrite /etc/snapraid.conf?' \
		"This replaces ${SR_CONF}.  Changing 'data' names or
parity paths after a sync will break parity recovery.  Safe
only on first install or if no sync has run." \
		"mv ${SR_CONF} ${SR_CONF}.bak-\$(date +%s)" \
		"cat > ${SR_CONF} <<EOF (proposed content shown above)" \
		|| exit 1

	cp "$SR_CONF" "${SR_CONF}.bak-$(date +%s)"
fi

_tmp=$(mktemp "${SR_CONF}.XXXXXX")
printf '%s\n' "$_proposed" > "$_tmp"
chmod 0644 "$_tmp"
mv "$_tmp" "$SR_CONF"

sr_ok "wrote ${SR_CONF}"
cat "$SR_CONF"
