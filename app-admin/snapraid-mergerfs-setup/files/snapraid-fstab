#!/bin/sh
# Generate fstab entries from /etc/snapraid-roles.conf, splice them
# into /etc/fstab between markers, and run mount -a.  Idempotent.
#
# Usage: snapraid-fstab [--force]
set -o errexit
set -o nounset

. /usr/local/lib/snapraid-helpers.sh
sr_require_root
sr_parse_force "$@"

readonly FSTAB='/etc/fstab'
readonly BEGIN_MARK='# >>> snapraid-mergerfs (managed) >>>'
readonly END_MARK='# <<< snapraid-mergerfs (managed) <<<'

# XFS mount options:
#   noatime          no atime writes; HDDs hate atime
#   inode64          allow inodes anywhere on disk (default 64-bit)
#   logbufs=8        max log buffers; helps write bursts
#   nofail           do not block boot if enclosure is off
#   x-systemd.device-timeout=30s    fail fast on missing device
readonly XFS_MNT='defaults,noatime,inode64,logbufs=8,nofail,x-systemd.device-timeout=30s'

# MergerFS options (data branches only):
#   category.create=mfs        most-free-space create policy
#   moveonenospc=true          on ENOSPC, move file to another branch
#   cache.files=off            let kernel page cache do its job
#   dropcacheonclose=true      reduce memory pressure after writes
#   minfreespace=50G           stop targeting a branch under 50G
#   use_ino                    consistent inodes across pool
#   func.getattr=newest        prefer newest copy on collisions
#
# Note: 'nofail' is intentionally absent here.  libfuse rejects
# unknown options ("fuse: unknown option `nofail'") and util-linux
# does not strip it for FUSE helpers the way it does for in-kernel
# filesystems.  We get nofail-equivalent semantics for free: every
# data branch carries 'nofail' and the line below has
# x-systemd.requires= for every branch, so if any branch is missing
# systemd skips the mergerfs mount without failing the boot.
readonly MFS_REQS='x-systemd.requires=/mnt/snapraid0/data1,x-systemd.requires=/mnt/snapraid0/data2,x-systemd.requires=/mnt/snapraid0/data3'
readonly MFS_OPTS="cache.files=off,dropcacheonclose=true,category.create=mfs,moveonenospc=true,minfreespace=50G,use_ino,func.getattr=newest,fsname=mergerfs-storage,${MFS_REQS}"

sr_header 'Generate fstab entries'

[ -f "$SR_ROLES_FILE" ] || {
	sr_err "${SR_ROLES_FILE} missing; run snapraid-detect first"
	exit 1
}

# Build the proposed fragment.
_fragment=$(
	printf '# Generated by snapraid-fstab.  Do not edit by hand.\n'
	while read -r _role _idx _link; do
		case "$_role" in '#'*|'') continue ;; esac
		_mnt="/mnt/snapraid0/${_role}${_idx}"
		_part="${_link}-part1"
		printf '%s %s xfs %s 0 2\n' \
			"$_part" "$_mnt" "$XFS_MNT"
	done < "$SR_ROLES_FILE"
	printf '/mnt/snapraid0/data1:/mnt/snapraid0/data2:/mnt/snapraid0/data3 /mnt/snapraid0/storage fuse.mergerfs %s 0 0\n' \
		"$MFS_OPTS"
)

# Compute proposed full fstab.
_tmp_fstab=$(mktemp)
if grep -qF "$BEGIN_MARK" "$FSTAB"; then
	awk -v b="$BEGIN_MARK" -v e="$END_MARK" -v frag="$_fragment" '
		$0 == b { print; print frag; skip=1; next }
		$0 == e { skip=0; print; next }
		!skip
	' "$FSTAB" > "$_tmp_fstab"
else
	cp "$FSTAB" "$_tmp_fstab"
	{
		printf '\n%s\n' "$BEGIN_MARK"
		printf '%s\n' "$_fragment"
		printf '%s\n' "$END_MARK"
	} >> "$_tmp_fstab"
fi

# Idempotency check.
if cmp -s "$FSTAB" "$_tmp_fstab" && [ "$SR_FORCE" != '1' ]; then
	sr_skip "${FSTAB} already up to date"
	rm -f "$_tmp_fstab"
else
	# Show diff.
	gum style --margin '1 2' --bold "Proposed changes to ${FSTAB}:"
	_diff=$(diff -u "$FSTAB" "$_tmp_fstab" || true)
	gum style --foreground "$_SR_DIM_FG" --margin '0 2' -- "$_diff"

	sr_confirm \
		'Update /etc/fstab?' \
		"This rewrites ${FSTAB} with the diff shown above.  A
backup of the current file is saved to
${FSTAB}.bak-<timestamp>." \
		"cp ${FSTAB} ${FSTAB}.bak-\$(date +%s)" \
		"mv <new fstab> ${FSTAB}" \
		|| { rm -f "$_tmp_fstab"; exit 1; }

	cp "$FSTAB" "${FSTAB}.bak-$(date +%s)"
	chmod 0644 "$_tmp_fstab"
	mv "$_tmp_fstab" "$FSTAB"
	sr_ok "updated ${FSTAB}"
fi

# Ensure mount points exist.
sr_header 'Create mount points'
for _m in /mnt/snapraid0/parity1 /mnt/snapraid0/parity2 /mnt/snapraid0/data1 /mnt/snapraid0/data2 \
		/mnt/snapraid0/data3 /mnt/snapraid0/storage; do
	if [ -d "$_m" ]; then
		sr_skip "${_m} exists"
	else
		mkdir -p "$_m"
		sr_ok "created ${_m}"
	fi
done

# Reload systemd and offer to mount.
sr_header 'Reload systemd and mount'
systemctl daemon-reload
sr_ok 'systemctl daemon-reload'

# Check what's already mounted.
_unmounted=''
for _m in /mnt/snapraid0/parity1 /mnt/snapraid0/parity2 /mnt/snapraid0/data1 /mnt/snapraid0/data2 \
		/mnt/snapraid0/data3 /mnt/snapraid0/storage; do
	if ! mountpoint -q "$_m"; then
		_unmounted="${_unmounted}${_m}
"
	fi
done

if [ -z "$_unmounted" ]; then
	sr_ok 'all mount points already mounted'
	exit 0
fi

gum style --margin '1 2' --bold 'Not yet mounted:'
echo "$_unmounted" | while read -r _m; do
	[ -n "$_m" ] || continue
	sr_warn "$_m"
done

sr_confirm \
	'Run mount -a now?' \
	'This mounts all entries in fstab including the new ones.
Read-only operation that fails safely on errors.' \
	'mount -a' \
	|| exit 1

mount -a
sr_ok 'mount -a completed'
